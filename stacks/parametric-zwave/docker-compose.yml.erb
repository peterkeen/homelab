<%-
hosts = %w[house shed office garage]
-%>

services:
  <%- hosts.each_with_index do |name, i| -%>
  <%- ui_port = 8091 + i -%>
  <%- ws_port = 3000 + i -%>
  zwave-<%= name %>:
    container_name: zwave-<%= name %>
    hostname: zwave-<%= name %>
    image: ghcr.io/zwave-js/zwave-js-ui:11.3.0
    restart: always
    stop_signal: SIGINT
    ports:
      - ${TAILNET_IP}:<%= ui_port %>:8091
      - ${TAILNET_IP}:<%= ws_port %>:3000
    environment:
      - ZWAVEJS_EXTERNAL_CONFIG=/usr/src/app/store/.config-db
      - CONFIGS_SHA
    volumes:
      - /data/zwave/<%= name %>:/usr/src/app/store
    x-backup:
      paths:
        - /data/zwave/<%= name %>
  <%- end -%>
