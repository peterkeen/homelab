<%-
hosts = %w[house office]
-%>

services:
  <%- hosts.each_with_index do |name, i| -%>
  <%- ui_port = 8080 + i -%>
  <%= name %>:
    container_name: zigbee-<%= name %>
    hostname: zigbee-<%= name %>
    image: ghcr.io/koenkk/zigbee2mqtt:2
    restart: always
    stop_signal: SIGINT
    environment:
      - TZ=America/Detroit
    ports:
      - '${TAILNET_IP}:<%= ui_port %>:8080'
    volumes:
      - /data/zigbee/<%= name %>:/app/data
    x-backup:
      paths:
        - /data/zigbee/<%= name %>
  <%- end -%>   
