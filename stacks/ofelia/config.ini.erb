[global]
smtp-host = smtp-relay
smtp-port = 2525
email-to = pete@keenfamily.us
email-from = <%= this_host.hostname %>+cron@keen.land

<%- this_host_services do |stack, service_name, service| -%>
<%- service.fetch("x-cron", []).each do |cron| -%>
[job-exec "<%= cron.fetch("name") %>"]
schedule = <%= cron.fetch("schedule") %>
container = <%= service["container_name"] %>
command = <%= cron.fetch("command") %>
mail-only-on-error = <%= cron.fetch("mail_only_on_error", "false") %>
no-overlap = true

<%- end -%>
<%- end -%>
